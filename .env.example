# =====================================================================
# Baja Dental AI — environment template
# Copy to .env (git-ignored) and fill in. NEVER commit real secrets.
# Edge Function secrets are set with:
#   supabase secrets set KEY=value --project-ref <PROJECT_REF>
# =====================================================================

# --- Supabase --------------------------------------------------------
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are auto-injected into deployed
# Edge Functions; set them here only for local runs.
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Vapi (voice) ----------------------------------------------------
VAPI_API_KEY=<vapi-PRIVATE-key>                 # server key — used to place outbound calls
VAPI_ASSISTANT_ID=<inbound-sofia-assistant-id>  # inbound receptionist "Sofía"
VAPI_PUBLIC_KEY=<vapi-public-key>               # web demo only (safe for the browser)

# --- Vapi outbound reminders (Phase B) -------------------------------
VAPI_REMINDER_ASSISTANT_ID=<sofia-recordatorios-assistant-id>  # reminder persona (vapi_config/reminder_call_prompt.txt)
VAPI_OUTBOUND_PHONE_NUMBER_ID=<vapi-phoneNumberId>             # the Telnyx number registered in Vapi for outbound
DEFAULT_CLINIC_NAME=la clínica                                 # fallback used when an appointment has no clinic

# --- Telnyx (telephony + staff SMS) ----------------------------------
TELNYX_API_KEY=<telnyx-api-key>
TELNYX_PHONE_NUMBER=+1760XXXXXXX                # SMS-enabled "from" number for staff alerts
CLINIC_ALERT_PHONE=+1XXXXXXXXXX                 # staff/closer number that receives lead + reschedule alerts
TELNYX_MESSAGING_PROFILE_ID=                    # optional

# --- Reminder scheduler (pg_cron → reminder-dispatch) ----------------
CRON_SECRET=<random-string>                     # must match the x-cron-secret header sent by the pg_cron job
